# Browser-safe (Vite exposes only VITE_-prefixed variables to client code).
# The anon key is safe to ship publicly — RLS (016_rls.sql) is the real
# access-control boundary, not secrecy of this key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# SERVER-ONLY. Never prefix with VITE_, never reference from frontend
# code. Used exclusively by src/lib/supabase/adminClient.server.ts for
# privileged operations such as admin_user provisioning via the Auth
# Admin API (see 019_auth_bootstrap.sql's actor_type gate).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
